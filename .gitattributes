# 这些文件强制使用 LF 换行符
# 否则 Windows 用户提交后，GitHub Actions 的 bash 会报错
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.py        text eol=lf

# Markdown 也统一 LF，避免不同系统 diff 噪音
*.md        text eol=lf
*.toml      text eol=lf

# Windows 专属脚本保留 CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf
